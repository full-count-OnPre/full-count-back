generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// 팀 정보
// ─────────────────────────────────────────
model Team {
  id     String  @id @default(cuid())
  name   String // Yankees
  code   String  @unique // NYY
  city   String // New York
  logo   String?
  league String? // AL / NL
  color  String? // #132448
  accent String? // #c4ced4

  homeGames Game[] @relation("HomeTeam")
  awayGames Game[] @relation("AwayTeam")
}

// ─────────────────────────────────────────
// 경기 정보
// ─────────────────────────────────────────
model Game {
  id        String   @id @default(cuid())
  gamePk    String   @unique // 20260311-nyy-lad
  season    Int
  startTime DateTime
  venue     String
  weather   String?
  status    Int      @default(0) // 0: 예정, 1: 진행중, 2: 종료

  homeTeamId String
  awayTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  homeScore  Int @default(0)
  awayScore  Int @default(0)
  homeHits   Int @default(0)
  awayHits   Int @default(0)
  homeErrors Int @default(0)
  awayErrors Int @default(0)

  // 이닝별 점수 배열 (인덱스 = 이닝-1)
  homeInningScores Int[]
  awayInningScores Int[]

  // 현재 경기 상황
  currentInning  Int     @default(1)
  inningHalf     String  @default("TOP") // TOP / BOTTOM
  balls          Int     @default(0)
  strikes        Int     @default(0)
  outs           Int     @default(0)
  base1b         Boolean @default(false)
  base2b         Boolean @default(false)
  base3b         Boolean @default(false)
  currentBatter  String?
  currentPitcher String?
  lastPitch      String?

  // 부가 정보
  attendance  String?
  probableMvp String?

  // 선발 라인업 JSON 배열
  homeLineup Json?
  awayLineup Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  events   GameEvent[]
  messages Message[]
}

// ─────────────────────────────────────────
// 실시간 문자중계 이벤트
// ─────────────────────────────────────────
model GameEvent {
  id     Int    @id @default(autoincrement())
  gameId String
  game   Game   @relation(fields: [gameId], references: [id])

  inning     Int
  inningHalf String // TOP / BOTTOM
  outs       Int
  balls      Int
  strikes    Int
  base1b     Boolean @default(false)
  base2b     Boolean @default(false)
  base3b     Boolean @default(false)

  headline String
  detail   String?
  tag      String? // HR, RBI, K, DP, NOTE ...

  homeScore Int
  awayScore Int
  batter    String?
  pitcher   String?

  occurredAt DateTime @default(now())
}

// ─────────────────────────────────────────
// 실시간 댓글 (채팅)
// ─────────────────────────────────────────
model Message {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  gameId    String
  game      Game     @relation(fields: [gameId], references: [id])
  message   String
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────
// 사용자 
// ─────────────────────────────────────────
model User {
  id        String    @id @default(cuid())
  nickname  String?
  email     String    @unique
  passwordHash String
  role      String    @default("user")
  isAdmin   Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  messages Message[]
}

// ─────────────────────────────────────────
// 이메일 인증 코드 
// ─────────────────────────────────────────
model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  createdAt DateTime @default(now())
  expiresAt DateTime
}
